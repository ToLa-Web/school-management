{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SchoolDb": "Host=school-db;Port=5432;Database=school_db;Username=school_user;Password=school_pass"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients"
  },
  "spring": {
    "application": {
      "name": "school-service"
    }
  },
  "consul": {
    "host": "consul",
    "port": 8500,
    "discovery": {
      "serviceName": "school-service",
      "healthCheck": "/health",
      "tags": [ "school", "api" ]
    }
  }
}
