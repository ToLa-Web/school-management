{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AuthDb": "Host=auth-db;Port=5432;Database=auth_db;Username=auth_user;Password=auth_pass"
  },
  "EmailSettings": {
    "FromEmail": "",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUser": "",
    "AppPassword": ""
  },
  "EmailVerification": {
    "Pepper": "CHANGE_ME_TO_A_RANDOM_SECRET"
  },
  "Authentication": {
  "Google": { 
    "ClientId": "REMOVED_GOOGLE_CLIENT_ID"
  },
  "Facebook": { 
    "AppId": "YOUR_FACEBOOK_APP_ID", 
    "AppSecret": "REMOVED_FACEBOOK_APP_SECRET" 
  }
},
  "spring": {
    "application": {
      "name": "auth-service"
    }
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "AuthService",
    "Audience": "AuthServiceClients",
    "ExpirationMinutes": "60"
  },
  "consul": {
    "host": "consul",
    "port": 8500,
    "discovery": {
      "serviceName": "auth-service",
      "healthCheck": "/health",
      "tags": [ "auth", "api" ]
    }
  }
}
