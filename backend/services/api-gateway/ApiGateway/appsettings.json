{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ]
      },
      "school-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/school/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/school/{**catch-all}"
          }
        ]
      },
      "servicehealth-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/servicehealth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/servicehealth/{**catch-all}"
          }
        ]
      },
      "announcements-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/announcements/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/announcements/{**catch-all}"
          }
        ]
      },
      "rooms-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/rooms/{**catch-all}"
          }
        ]
      },
      "materials-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/materials/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/materials/{**catch-all}"
          }
        ]
      },
      "submissions-route": {
        "ClusterId": "school-cluster",
        "Match": {
          "Path": "/api/submissions/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/submissions/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-service:8080/"
          }
        }
      },
      "school-cluster": {
        "Destinations": {
          "school-service": {
            "Address": "http://school-service:8080/"
          }
        }
      }
    }
  },
  "spring": {
    "application": {
      "name": "api-gateway"
    }
  },
  "consul": {
    "host": "consul",
    "port": 8500,
    "discovery": {
      "serviceName": "api-gateway",
      "healthCheck": "/health",
      "tags": [ "gateway" ]
    }
  }
}
