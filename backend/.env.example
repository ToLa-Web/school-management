# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# JWT signing secret — minimum 32 characters
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Gmail sender address
EMAILSETTINGS_FROM_EMAIL=your_email@gmail.com
# Gmail SMTP username (usually the same as FROM_EMAIL)
EMAILSETTINGS_SMTP_USER=your_email@gmail.com
# Gmail App Password (generate at myaccount.google.com -> Security -> App passwords)
EMAILSETTINGS_APP_PASSWORD=your_gmail_app_password

# pgAdmin web UI credentials
PGADMIN_EMAIL=admin@school.com
PGADMIN_PASSWORD=change_me

# Google OAuth Client ID (from console.cloud.google.com)
# Used by the backend auth-service via environment variable injection (docker-compose).
# For the Flutter app, put this value in frontend/secrets.json (see secrets.example.json).
GOOGLE_CLIENT_ID=your_google_client_id

# Facebook OAuth credentials (from developers.facebook.com)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CLIENT_TOKEN=your_facebook_client_token
